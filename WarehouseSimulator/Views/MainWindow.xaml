<Window x:Class="WarehouseSimulator.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:WarehouseSimulator.ViewModels"
        xmlns:local="clr-namespace:WarehouseSimulator.Views"
        xmlns:res="clr-namespace:WarehouseSimulator.Resources"
        Title="{Binding Source={x:Static res:TranslationSource.Instance}, Path=[WindowTitle]}"
        Height="820" Width="1400"
        MinHeight="700" MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BrushBackgroundDark}">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <local:BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:NullToVisibilityConverter x:Key="NullToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="32"/>
        </Grid.RowDefinitions>

        <!-- ========================================= -->
        <!--  HEADER BAR                              -->
        <!-- ========================================= -->
        <Border Grid.Row="0"
                Background="{StaticResource BrushBackgroundMid}"
                BorderBrush="{StaticResource BrushBorder}"
                BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo + Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="📦" FontSize="24" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding Source={x:Static res:TranslationSource.Instance}, Path=[AppTitle]}"
                                   Foreground="{StaticResource BrushTextPrimary}"
                                   FontFamily="Segoe UI"
                                   FontWeight="Bold"
                                   FontSize="16"/>
                        <TextBlock Text="{Binding Source={x:Static res:TranslationSource.Instance}, Path=[AppSubtitle]}"
                                   Foreground="{StaticResource BrushTextSecondary}"
                                   FontFamily="Segoe UI"
                                   FontSize="11"/>
                    </StackPanel>
                </StackPanel>

                <!-- Summary info -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center"
                            Visibility="{Binding IsWarehouseBuilt, Converter={StaticResource BoolToVis}}">
                    <Border Background="{StaticResource BrushBackgroundLight}"
                            CornerRadius="20" Padding="12,4" Margin="8,0">
                        <TextBlock Foreground="{StaticResource BrushAccentBlue}"
                                   FontFamily="Segoe UI" FontSize="12">
                            <Run Text="{Binding Source={x:Static res:TranslationSource.Instance}, Path=[HeaderBlock]}"/>
                            <Run Text="{Binding BlockCount, Mode=OneWay}"/>
                            <Run Text="{Binding Source={x:Static res:TranslationSource.Instance}, Path=[HeaderAisle]}"/>
                            <Run Text="{Binding AislesPerBlock, Mode=OneWay}"/>
                            <Run Text="{Binding Source={x:Static res:TranslationSource.Instance}, Path=[HeaderShelfPerAisle]}"/>
                            <Run Text="{Binding ShelvesPerAisle, Mode=OneWay}"/>
                        </TextBlock>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ========================================= -->
        <!--  MAIN CONTENT (3 Columns)                -->
        <!-- ========================================= -->
        <Grid Grid.Row="1" Margin="12,10,12,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <!-- ===================================== -->
            <!--  LEFT PANEL: Parameters              -->
            <!-- ===================================== -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,8,0">
                <StackPanel>

                    <!-- Warehouse Design Card -->
                    <Border Style="{StaticResource CardBorder}" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="{Binding Source={x:Static res:TranslationSource.Instance}, Path=[WarehouseDesign]}" Style="{StaticResource SectionHeader}"/>

                            <TextBlock Text="{Binding Source={x:Static res:TranslationSource.Instance}, Path=[BlockCount]}" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="txtBlockCount" Style="{StaticResource ModernTextBox}"
                                     Text="{Binding BlockCount, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Text="{Binding Source={x:Static res:TranslationSource.Instance}, Path=[AisleCount]}" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="txtAisles" Style="{StaticResource ModernTextBox}"
                                     Text="{Binding AislesPerBlock, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Text="{Binding Source={x:Static res:TranslationSource.Instance}, Path=[ShelfCount]}" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="txtShelves" Style="{StaticResource ModernTextBox}"
                                     Text="{Binding ShelvesPerAisle, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Text="{Binding Source={x:Static res:TranslationSource.Instance}, Path=[DoorLocation]}" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="cmbDoor" Style="{StaticResource ModernComboBox}"
                                      SelectedIndex="{Binding DoorLocation}"
                                      Margin="0,0,0,4">
                                <ComboBoxItem Content="{Binding Source={x:Static res:TranslationSource.Instance}, Path=[DoorLeft]}"/>
                                <ComboBoxItem Content="{Binding Source={x:Static res:TranslationSource.Instance}, Path=[DoorRight]}"/>
                                <ComboBoxItem Content="{Binding Source={x:Static res:TranslationSource.Instance}, Path=[DoorCenter]}"/>
                            </ComboBox>

                            <!-- Optional: Distance parameters -->
                            <Expander Header="{Binding Source={x:Static res:TranslationSource.Instance}, Path=[DistanceParameters]}"
                                      Foreground="{StaticResource BrushTextSecondary}"
                                      Margin="0,6,0,0">
                                <StackPanel Margin="0,4,0,0">
                                    <TextBlock Text="{Binding Source={x:Static res:TranslationSource.Instance}, Path=[AisleLength]}" Style="{StaticResource FieldLabel}"/>
                                    <TextBox Style="{StaticResource ModernTextBox}"
                                             Text="{Binding AisleLength, UpdateSourceTrigger=PropertyChanged}"/>

                                    <TextBlock Text="{Binding Source={x:Static res:TranslationSource.Instance}, Path=[CrossAisleDistance]}" Style="{StaticResource FieldLabel}"/>
                                    <TextBox Style="{StaticResource ModernTextBox}"
                                             Text="{Binding CrossAisleDistance, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                            </Expander>

                            <Button Content="{Binding Source={x:Static res:TranslationSource.Instance}, Path=[ShowWarehouse]}"
                                    Style="{StaticResource PrimaryButton}"
                                    Click="BtnBuildWarehouse_Click"
                                    Margin="0,12,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Order Creation Card -->
                    <Border Style="{StaticResource CardBorder}" Margin="0,0,0,8"
                            IsEnabled="{Binding IsWarehouseBuilt}">
                        <StackPanel>
                            <TextBlock Text="{Binding Source={x:Static res:TranslationSource.Instance}, Path=[OrderCreation]}" Style="{StaticResource SectionHeader}"/>

                            <TextBlock Text="{Binding Source={x:Static res:TranslationSource.Instance}, Path=[RandomProductCount]}" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource ModernTextBox}"
                                     Text="{Binding RandomOrderCount, UpdateSourceTrigger=PropertyChanged}"/>

                            <Button Content="{Binding Source={x:Static res:TranslationSource.Instance}, Path=[RandomOrder]}"
                                    Style="{StaticResource SuccessButton}"
                                    Click="BtnRandomOrder_Click"
                                    Margin="0,8,0,4"/>

                            <TextBlock Text="{Binding Source={x:Static res:TranslationSource.Instance}, Path=[OrClickShelves]}"
                                       Foreground="{StaticResource BrushTextSecondary}"
                                       FontFamily="Segoe UI" FontSize="10"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,4"/>

                            <Button Content="{Binding Source={x:Static res:TranslationSource.Instance}, Path=[ClearOrder]}"
                                    Style="{StaticResource DangerButton}"
                                    Click="BtnClearOrder_Click"
                                    Margin="0,0,0,8"/>

                            <CheckBox Content="{Binding Source={x:Static res:TranslationSource.Instance}, Path=[ShowHeatmap]}"
                                      IsChecked="{Binding IsHeatmapVisible}"
                                      Foreground="{StaticResource BrushTextSecondary}"
                                      FontFamily="Segoe UI" FontSize="11"
                                      Margin="0,4,0,0"
                                      Checked="Heatmap_Changed"
                                      Unchecked="Heatmap_Changed"/>

                            <!-- Order summary -->
                            <Border Background="{StaticResource BrushBackgroundLight}"
                                    CornerRadius="6" Padding="8" Margin="0,8,0,0"
                                    Visibility="{Binding HasOrder, Converter={StaticResource BoolToVis}}">
                                <TextBlock FontFamily="Segoe UI" FontSize="12">
                                    <Run Text="{Binding Source={x:Static res:TranslationSource.Instance}, Path=[SelectedProduct]}" Foreground="{StaticResource BrushTextSecondary}"/>
                                    <Run Text="{Binding CurrentOrder.ItemCount, Mode=OneWay}"
                                         Foreground="{StaticResource BrushAccentGreen}"
                                         FontWeight="Bold"/>
                                </TextBlock>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Algorithm Card -->
                    <Border Style="{StaticResource CardBorder}"
                            IsEnabled="{Binding HasOrder}">
                        <StackPanel>
                            <TextBlock Text="{Binding Source={x:Static res:TranslationSource.Instance}, Path=[RouteCalculation]}" Style="{StaticResource SectionHeader}"/>

                            <TextBlock Text="{Binding Source={x:Static res:TranslationSource.Instance}, Path=[AutoRunDescription]}"
                                       Foreground="{StaticResource BrushTextSecondary}"
                                       FontFamily="Segoe UI" FontSize="10"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8"/>

                            <Button Content="{Binding Source={x:Static res:TranslationSource.Instance}, Path=[CalculateAllRoutes]}"
                                    Style="{StaticResource WarningButton}"
                                    Click="BtnCalculateRoutes_Click"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- ===================================== -->
            <!--  CENTER: Warehouse Visualization    -->
            <!-- ===================================== -->
            <Border Grid.Column="1"
                    Style="{StaticResource CardBorder}"
                    Margin="0,0,8,0"
                    Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="36"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Visualization header -->
                    <Border Grid.Row="0"
                            Background="{StaticResource BrushBackgroundLight}"
                            CornerRadius="10,10,0,0"
                            Padding="14,8">
                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Source={x:Static res:TranslationSource.Instance}, Path=[WarehouseMap]}"
                                           Foreground="{StaticResource BrushAccentBlue}"
                                           FontFamily="Segoe UI"
                                           FontWeight="Bold" FontSize="12"/>
                            </StackPanel>

                            <!-- Legend -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Rectangle Width="14" Height="14" Fill="#FF2E86AB" RadiusX="2" RadiusY="2" Margin="0,0,4,0"/>
                                <TextBlock Text="{Binding Source={x:Static res:TranslationSource.Instance}, Path=[LegendRack]}" Foreground="{StaticResource BrushTextSecondary}"
                                           FontSize="10" Margin="0,0,12,0"/>
                                <Rectangle Width="14" Height="14" Fill="#FFFF6B35" RadiusX="2" RadiusY="2" Margin="0,0,4,0"/>
                                <TextBlock Text="{Binding Source={x:Static res:TranslationSource.Instance}, Path=[LegendSelected]}" Foreground="{StaticResource BrushTextSecondary}"
                                           FontSize="10" Margin="0,0,12,0"/>
                                <Rectangle Width="14" Height="14" Fill="#FFFF2D2D" RadiusX="2" RadiusY="2" Margin="0,0,4,0"/>
                                <TextBlock Text="{Binding Source={x:Static res:TranslationSource.Instance}, Path=[LegendRoute]}" Foreground="{StaticResource BrushTextSecondary}"
                                           FontSize="10"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Canvas container -->
                    <ScrollViewer Grid.Row="1"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  Background="{StaticResource BrushBackgroundDark}">
                        <Canvas x:Name="warehouseCanvas"
                                Background="{StaticResource BrushBackgroundDark}"
                                Width="2000" Height="1000">
                        </Canvas>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- ===================================== -->
            <!--  RIGHT PANEL: Results               -->
            <!-- ===================================== -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Algorithm Results Card -->
                <Border Grid.Row="0" Style="{StaticResource CardBorder}" Margin="0,0,0,8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="{Binding Source={x:Static res:TranslationSource.Instance}, Path=[AlgorithmComparison]}"
                                   Style="{StaticResource SectionHeader}"/>

                        <DataGrid Grid.Row="1"
                                  x:Name="dgResults"
                                  Style="{StaticResource ModernDataGrid}"
                                  ItemsSource="{Binding AlgorithmResults}"
                                  SelectedItem="{Binding SelectedResult}"
                                  SelectionChanged="DgResults_SelectionChanged"
                                  ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="⭐" Width="28">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="🏆"
                                                       Visibility="{Binding IsBest,
                                                           Converter={StaticResource BoolToVis}}"
                                                       HorizontalAlignment="Center"
                                                       FontSize="13"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="{Binding Source={x:Static res:TranslationSource.Instance}, Path=[ColAlgorithm]}"
                                                   Binding="{Binding AlgorithmName}"
                                                   Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
                                            <Setter Property="FontSize" Value="11"/>
                                            <Setter Property="TextWrapping" Value="Wrap"/>
                                            <Setter Property="Padding" Value="4,3"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="{Binding Source={x:Static res:TranslationSource.Instance}, Path=[ColDistance]}"
                                                   Binding="{Binding TotalDistance, StringFormat={}{0:F1}}"
                                                   Width="65">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource BrushAccentYellow}"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="FontSize" Value="12"/>
                                            <Setter Property="TextAlignment" Value="Right"/>
                                            <Setter Property="Padding" Value="4,3"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>

                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsBest}" Value="True">
                                            <Setter Property="Background" Value="#1A06D6A0"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource BrushAccentGreen}"/>
                                        </DataTrigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#1A2E86AB"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                        </DataGrid>
                    </Grid>
                </Border>

                <!-- Selected Route Detail Card -->
                <Border Grid.Row="1" Style="{StaticResource CardBorder}"
                        Visibility="{Binding SelectedResult,
                            Converter={StaticResource NullToVis}}">
                    <StackPanel>
                        <TextBlock Text="{Binding Source={x:Static res:TranslationSource.Instance}, Path=[RouteDetail]}" Style="{StaticResource SectionHeader}"/>

                        <TextBlock x:Name="txtAlgoName"
                                   Text="{Binding SelectedResult.AlgorithmName}"
                                   Foreground="{StaticResource BrushTextPrimary}"
                                   FontFamily="Segoe UI" FontWeight="Bold" FontSize="13"
                                   TextWrapping="Wrap"/>

                        <TextBlock Text="{Binding SelectedResult.Description}"
                                   Foreground="{StaticResource BrushTextSecondary}"
                                   FontFamily="Segoe UI" FontSize="11"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,8"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Background="{StaticResource BrushBackgroundLight}"
                                    CornerRadius="6" Padding="8" Margin="0,0,4,0">
                                <StackPanel>
                                    <TextBlock Text="{Binding Source={x:Static res:TranslationSource.Instance}, Path=[TotalDistance]}"
                                               Foreground="{StaticResource BrushTextSecondary}"
                                               FontSize="9" FontFamily="Segoe UI"/>
                                    <TextBlock Foreground="{StaticResource BrushAccentYellow}"
                                               FontWeight="Bold" FontSize="14"
                                               FontFamily="Segoe UI">
                                        <Run Text="{Binding SelectedResult.TotalDistance, StringFormat={}{0:F2}}"/>
                                        <Run Text="{Binding Source={x:Static res:TranslationSource.Instance}, Path=[UnitDistance]}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Background="{StaticResource BrushBackgroundLight}"
                                    CornerRadius="6" Padding="8" Margin="4,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="{Binding Source={x:Static res:TranslationSource.Instance}, Path=[ComputationTime]}"
                                               Foreground="{StaticResource BrushTextSecondary}"
                                               FontSize="9" FontFamily="Segoe UI"/>
                                    <TextBlock Foreground="{StaticResource BrushAccentGreen}"
                                               FontWeight="Bold" FontSize="14"
                                               FontFamily="Segoe UI">
                                        <Run Text="{Binding SelectedResult.ComputationTimeMs, StringFormat={}{0:F1}}"/>
                                        <Run Text="{Binding Source={x:Static res:TranslationSource.Instance}, Path=[UnitMs]}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Button Content="{Binding Source={x:Static res:TranslationSource.Instance}, Path=[ShowThisRoute]}"
                                Style="{StaticResource PrimaryButton}"
                                Click="BtnShowRoute_Click"
                                Margin="0,10,0,0"/>

                        <!-- Pick order list -->
                        <TextBlock Text="{Binding Source={x:Static res:TranslationSource.Instance}, Path=[PickOrder]}" Style="{StaticResource FieldLabel}" Margin="0,8,0,2"/>
                        <ListBox x:Name="lbPickOrder"
                                 ItemsSource="{Binding SelectedResult.PickOrder}"
                                 Background="{StaticResource BrushBackgroundLight}"
                                 BorderThickness="0"
                                 MaxHeight="140"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock FontFamily="Segoe UI" FontSize="11"
                                               Foreground="{StaticResource BrushTextSecondary}">
                                        <Run Text="{Binding PickSequence, Mode=OneWay}" Foreground="{StaticResource BrushAccentBlue}" FontWeight="Bold"/>
                                        <Run Text=". "/>
                                        <Run Text="{Binding Location.Label, Mode=OneWay}"/>
                                    </TextBlock>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Padding" Value="4,2"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- ========================================= -->
        <!--  STATUS BAR                             -->
        <!-- ========================================= -->
        <Border Grid.Row="2"
                Background="{StaticResource BrushBackgroundMid}"
                BorderBrush="{StaticResource BrushBorder}"
                BorderThickness="0,1,0,0">
            <Grid Margin="16,0">
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{StaticResource BrushTextSecondary}"
                           FontFamily="Segoe UI" FontSize="11"
                           VerticalAlignment="Center"/>
                <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal">
                    <TextBlock Foreground="{StaticResource BrushTextSecondary}"
                               FontFamily="Segoe UI" FontSize="10"
                               VerticalAlignment="Center">
                        <Run Text="{Binding Source={x:Static res:TranslationSource.Instance}, Path=[FooterText]}"/>
                        <Run Text="{Binding Source={x:Static res:TranslationSource.Instance}, Path=[FooterAlgorithms]}"/>
                    </TextBlock>
                    <!-- Language Switcher -->
                    <ComboBox x:Name="cmbLanguage" SelectedIndex="0"
                              Background="{StaticResource BrushBackgroundLight}"
                              Foreground="{StaticResource BrushTextPrimary}"
                              BorderBrush="{StaticResource BrushBorder}"
                              FontFamily="Segoe UI" FontSize="10"
                              Padding="4,2" Margin="12,0,0,0"
                              Width="90"
                              SelectionChanged="CmbLanguage_SelectionChanged">
                        <ComboBoxItem Content="🇹🇷 Türkçe"/>
                        <ComboBoxItem Content="🇬🇧 English"/>
                    </ComboBox>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
