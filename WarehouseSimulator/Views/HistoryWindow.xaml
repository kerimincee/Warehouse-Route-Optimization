<Window x:Class="WarehouseSimulator.Views.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:res="clr-namespace:WarehouseSimulator.Resources"
        Title="{Binding Source={x:Static res:TranslationSource.Instance}, Path=[HistoryTitle]}"
        Height="500" Width="700"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BrushBackgroundDark}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{Binding Source={x:Static res:TranslationSource.Instance}, Path=[HistoryHeader]}"
                   Foreground="{StaticResource BrushAccentBlue}"
                   FontFamily="Segoe UI" FontWeight="Bold" FontSize="14"
                   Margin="0,0,0,12"/>

        <DataGrid Grid.Row="1"
                  x:Name="dgHistory"
                  Style="{StaticResource ModernDataGrid}"
                  AutoGenerateColumns="False"
                  ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="{Binding Source={x:Static res:TranslationSource.Instance}, Path=[ColId]}" Binding="{Binding ID}" Width="Auto"/>
                <DataGridTextColumn Header="{Binding Source={x:Static res:TranslationSource.Instance}, Path=[ColItemCount]}" Binding="{Binding ItemCount}" Width="*"/>
                <DataGridTextColumn Header="{Binding Source={x:Static res:TranslationSource.Instance}, Path=[ColBestAlg]}" Binding="{Binding BestAlgo}" Width="*"/>
                <DataGridTextColumn Header="{Binding Source={x:Static res:TranslationSource.Instance}, Path=[ColDistanceShort]}" Binding="{Binding DistanceText}" Width="*"/>
                <DataGridTextColumn Header="{Binding Source={x:Static res:TranslationSource.Instance}, Path=[ColDate]}" Binding="{Binding Date}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <Button Grid.Row="2"
                Content="{Binding Source={x:Static res:TranslationSource.Instance}, Path=[CloseButton]}"
                Width="100" HorizontalAlignment="Right"
                Margin="0,10,0,0"
                Style="{StaticResource PrimaryButton}"
                Click="BtnClose_Click"/>
    </Grid>
</Window>
